# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env

# PostgreSQL (usado pelo docker-compose e pela aplicação)
PG_USER=synapse
PG_PASSWORD=synapse
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=synapse_search
DATABASE_URL=postgresql://${PG_USER}:${PG_PASSWORD}@${PG_HOST}:${PG_PORT}/${PG_DATABASE}

# Modelo de embedding (Hugging Face)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Aplicação
DEBUG=false
